# App
APP_NAME="OneSpace Scheduling Service"
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=onespace_scheduling

# Scheduler
SCHEDULER_JOBS_COLLECTION=apscheduler_jobs
SCHEDULER_TIMEZONE=UTC

# Webhook actions
# Allow webhook targets on loopback/private IPs. Keep false in prod (SSRF guard);
# set true in dev/test to hit a local listener.
WEBHOOK_ALLOW_PRIVATE_HOSTS=false
# Max chars of a webhook response body kept in each run record.
WEBHOOK_RESPONSE_MAX_CHARS=2048
# Timeout (seconds) for the best-effort notify callback.
NOTIFY_TIMEOUT_SECONDS=10
# Days to keep run history (TTL). 0 = keep forever.
RUN_HISTORY_TTL_DAYS=0
